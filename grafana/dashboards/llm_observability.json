  "panels": [
    {
      "title": "Input Token Consumption Counters (Cumulative)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(gen_ai_usage_input_tokens_total) by (gen_ai_request_model)",
          "legendFormat": "{{gen_ai_request_model}} - input"
        }
      ]
    },
    {
      "title": "Output Token Consumption Counters (Cumulative)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(gen_ai_usage_output_tokens_total) by (gen_ai_request_model)",
          "legendFormat": "{{gen_ai_request_model}} - output"
        }
      ]
    },
    {
      "title": "Total Token Consumption Counters (Cumulative)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(gen_ai_client_token_usage_sum) by (gen_ai_request_model)",
          "legendFormat": "{{gen_ai_request_model}} - Total"
        }
      ]
    },
    {
      "title": "Avg Tokens per Request",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "interval": "5m",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "(sum(increase(gen_ai_client_token_usage_sum[$__rate_interval])) by (gen_ai_request_model)) / (sum(increase(gen_ai_client_operation_duration_seconds_count[$__rate_interval])) by (gen_ai_request_model) > 0)",
          "legendFormat": "Avg Total tokens / total time - {{gen_ai_request_model}}"
        }
      ]
    },
    {
      "title": "Avg Cost per Request",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "interval": "5m",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "(sum(increase(gen_ai_client_token_usage_sum[$__rate_interval])) by (gen_ai_request_model) / 1000) * 0.002 / (sum(increase(gen_ai_client_operation_duration_seconds_count[$__rate_interval])) by (gen_ai_request_model) > 0)",
          "legendFormat": "Avg Cost per Request - {{gen_ai_request_model}}"
        }
      ]
    },
    {
      "title": "Latency per Model (OSS-20B vs OSS-120B)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "interval": "5m",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_operation_duration_seconds_bucket[$__rate_interval])) by (le, gen_ai_request_model))",
          "legendFormat": "{{gen_ai_request_model}} (P95)"
        }
      ]
    },
    {
      "title": "TTFT per Model (OSS-20B vs OSS-120B)",
